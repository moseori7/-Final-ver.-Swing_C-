#include <iostream>
using namespace std;


/* 배열이 순서대로 저장된다는 점을 이용해서
name 배열에 3번째 칸에 장서린이라는 이름이 저장된다면
balance에도 순서대로 저장이 되므로 3번째에 '장서린'이라는 사용자에 대한 금액이 저장될 것이다!
이 점을 이용해서 2개의 배열을 만들어주었다
*/
char name[100][20]; // 이름을 담을 배열 선언
int balance[100]; //해당 사용자의 계좌 안 금액을 담기 위한 배열 선언
int countAccount = 0; // 계좌의 개수를 세기 위한 변수 선언 (계좌의 개수가 0일때는 이체나 출금 이런건 아무것도 할 수 없으니)


// call by value 사용해보자!
/*이건 내가 직접 정의한 사용자 정의 함수이다! 이름과 잔액을 입력 받아서
해당 사용자명과 금액을 출력할 수 있도록하였다
그래서 printAcount(name[1], balnace[1]을 통해 출력할 수 있다*/
void printAccount(char userName[], int userBalance) {
    cout << "이름: " << userName << " | 잔액: " << userBalance << "원" << endl;
}

// call by address 사용해보자!
void deposit(int* userBalance, int money) {
    *userBalance = *userBalance + money;
}

// call by reference 사용해보자!
int withdraw(int& userBalance, int money) {
    if (userBalance < money) {
        return 0;
    }

    userBalance = userBalance - money;
    return 1;
}

// 사용자 이름을 비교해서 원하는 배열의 값을 가지고 올 수 있도록 하기 위해 설정한 함수!
// 그래서 같은 이름 =samename이라고 변수명을 붙여보았다
// 나중에 내가 등록한 사용자명이 아니면 해당 사용자가 없다고 출력되야하기 때문에 설정해주었다
int sameName(char a[], char b[]) {
    int i = 0;

    while (a[i] != '\0' && b[i] != '\0') {
        if (a[i] != b[i]) {
            return 0;
        }
        i++;
    }

    // 두 문자열이 모두 끝났는지 확인
    if (a[i] == '\0' && b[i] == '\0') {
        return 1;
    }

    return 0;
}


// samename함수를 이용해서 해당 사용자의 계좌가 몇 번째에 있는지 찾아준다!
int findAccount(char target[]) {
    for (int i = 0; i < countAccount; i++) {
        if (sameName(name[i], target) == 1) {
            return i;
        }
    }

    return -1;
}

// 1번 메뉴에 대한 사용자 정의 함수이다
// 먼저 계좌가 0개가 아닌지 if 문으로 확인 후에 그다음 시뮬레이션으로 넘어가도록 하였다
void menu1() {
    if (countAccount == 0) {
        cout << "현재 등록된 계좌가 없습니다." << endl;
        return;
    }

    cout << "\n===== 현재 등록된 계좌 리스트 =====" << endl;

    for (int i = 0; i < countAccount; i++) {
        printAccount(name[i], balance[i]);
    }
}


// 2번 메뉴에 대한 사용자 정의 함수이다
void menu2() {
    cout << "등록할 계좌 이름: ";
    cin >> name[countAccount];

    cout << "초기 잔액: ";
    cin >> balance[countAccount];

    countAccount++;

    cout << "계좌 등록이 완료되었습니다." << endl;
}


// 3번 메뉴에 대한 사용자 정의 함수이다
void menu3() {
    if (countAccount == 0) {
        cout << "현재 등록된 계좌가 없습니다." << endl;
        return;
    }

    //searchname이라는 찾을 이름을 입력할 변수를 설정해서 findaccount함수를 통해 내가 원하는 계좌를 찾는다
    //select는 입금을 고를지 출금을 고를지 입력 받기 위해서 설정했고
    //money는 얼마만큼 입금 또는 출금을 할지 받기 위해 설정했다
    char searchName[20];
    int select;
    int money;

    cout << "조회할 계좌 이름: ";
    cin >> searchName;

    int index = findAccount(searchName);

    if (index == -1) {
        cout << "존재하지 않는 계좌입니다." << endl;
        return;
    }

    cout << "현재 잔액: " << balance[index] << "원" << endl;

    cout << "1. 입금" << endl;
    cout << "2. 출금" << endl;
    cout << "선택: ";
    cin >> select;

    if (select != 1 && select != 2) {
        cout << "잘못된 번호입니다." << endl;
        return;
    }

    cout << "거래 금액: ";
    cin >> money;

    if (select == 1) {
        deposit(&balance[index], money);
        cout << "입금 완료!" << endl;
    }
    else if (select == 2) {
        if (withdraw(balance[index], money) == 0) {
            cout << "잔액이 부족합니다." << endl;
            return;
        }

        cout << "출금 완료!" << endl;
    }
}


// 4번 메뉴에 대한 사용자 정의 함수이다
void menu4() {
    if (countAccount == 0) {
        cout << "현재 등록된 계좌가 없습니다." << endl;
        return;
    }

    // 내가 돈을 보낼 계좌를 sendname, 돈을 받을 계좌를 receivename이라고 설정했다
    // 아까 3번 메뉴와 마찬가지로 money라는 변수를 사용했다 (그러나 같은 변수가 아니라는 점! 각각 3번 / 4번 메뉴에서만 활동한다)
    char sendName[20];
    char receiveName[20];
    int money;

    cout << "보내는 계좌 이름: ";
    cin >> sendName;

    cout << "받는 계좌 이름: ";
    cin >> receiveName;

    int sendIndex = findAccount(sendName);
    int receiveIndex = findAccount(receiveName);

    if (sendIndex == -1 || receiveIndex == -1) {
        cout << "잘못된 계좌 이름입니다." << endl;
        return;
    }

    cout << "이체할 금액: ";
    cin >> money;

    if (withdraw(balance[sendIndex], money) == 0) {
        cout << "잔액이 부족합니다." << endl;
        return;
    }

    deposit(&balance[receiveIndex], money);

    cout << "이체가 완료되었습니다." << endl;
}




// 프로그램 메인 파트!!!
int main() {
    int menu;

    while (1) {
        cout << "\n===== 은행 계좌 관리 시스템 =====\n" << endl;
        cout << "1. 현재 등록된 계좌 리스트 보기\n" << endl;
        cout << "2. 신규 계좌 등록\n" << endl;
        cout << "3. 입금 및 출금\n" << endl;
        cout << "4. 계좌 간 이체\n" << endl;
        cout << "5. 프로그램 종료\n" << endl;
        cout << "========================\n" << endl;
        cout << "메뉴 선택 : ";
        cin >> menu;

        if (menu == 1) {
            menu1();
        }
        else if (menu == 2) {
            menu2();
        }
        else if (menu == 3) {
            menu3();
        }
        else if (menu == 4) {
            menu4();
        }
        else if (menu == 5) {
            cout << "프로그램을 종료합니다." << endl;
            break;
        }
        else {
            cout << "잘못된 번호를 입력하였습니다. 다시 입력해주세요." << endl;
            continue;
        }
    }

    return 0;
}

