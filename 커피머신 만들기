#include <iostream>
using namespace std;

class CoffeeMachine {
private:
    int waterAmount;
    int iceAmount;
    int beanAmount;
    int cupAmount;

    int grindTime;
    int tampLevel;
    int shotTime;

public:
    CoffeeMachine();                      // 기본 생성자
    CoffeeMachine(int w, int i, int b, int c); // 매개변수 생성자
    ~CoffeeMachine();                     // 소멸자
};

// 기본 생성자
CoffeeMachine::CoffeeMachine() {
    waterAmount = 0;
    iceAmount = 0;
    beanAmount = 0;
    cupAmount = 0;

    grindTime = 4;
    tampLevel = 3;
    shotTime = 25;

    cout << "--- 에스프레소 머신이 초기화되었습니다 ---" << endl;
}

// 매개변수 생성자
CoffeeMachine::CoffeeMachine(int w, int i, int b, int c) {
    waterAmount = w;
    iceAmount = i;
    beanAmount = b;
    cupAmount = c;

    grindTime = 3;
    tampLevel = 3;
    shotTime = 26;

    cout << "--- 재료가 설정된 에스프레소 머신이 생성되었습니다 ---" << endl;
}

// 소멸자
CoffeeMachine::~CoffeeMachine() {
    cout << "--- 에스프레소 머신이 종료됩니다 ---" << endl;
}
